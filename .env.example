# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# MercadoPago
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...
MP_ACCESS_TOKEN=APP_USR-...

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=tu@email.com

# Notificaciones — Email (Gmail SMTP)
# 1. Activá verificación en 2 pasos en Gmail
# 2. Generá una contraseña de app en myaccount.google.com/apppasswords
GMAIL_USER=tu@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFICATION_EMAIL=tu@gmail.com

# Notificaciones — WhatsApp (Green API, gratis 500 msg/mes)
# 1. Creá cuenta en green-api.com
# 2. Creá instancia gratuita (plan Developer)
# 3. Escaneá el QR con tu WhatsApp
# 4. Copiá Instance ID y Token
GREEN_API_INSTANCE_ID=TU_INSTANCE_ID
GREEN_API_TOKEN=TU_API_TOKEN
WHATSAPP_NOTIFY_PHONE=5491100000000
